{
  "name": "metnmat",
  "version": "0.1.0",
  "private": true,
  "description": "METNMAT Research & Innovations — platform monorepo (Website + Operations Dashboard).",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "start": "pnpm --filter website start",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md,css}\""
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@11.5.1",
  "engines": {
    "node": ">=20"
  }
}
