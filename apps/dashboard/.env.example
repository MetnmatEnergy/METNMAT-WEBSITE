# ── METNMAT dashboard (Payload CMS) environment ───────────────────────────────
# Copy to `.env` (gitignored) and fill in. NEVER commit real secrets.
# In production these should come from a secret manager, not a file on disk.

# ── Core ──────────────────────────────────────────────────────────────────────
# Payload signing secret (JWT + admin cookie). MUST be a long random value and
# MUST be set in production — the app should refuse to boot with an empty secret.
# Generate with:  openssl rand -hex 32
PAYLOAD_SECRET=
# Mongo connection string for the CMS database (metnmat_cms).
MONGODB_URI=
# Optional explicit DB name override.
MONGODB_DB=

# ── PIN login ─────────────────────────────────────────────────────────────────
# HMAC pepper for the 4-digit staff PIN -> password derivation. MUST be a long
# random value (NOT a short number). Required in production. Rotating it
# invalidates existing PIN logins, so coordinate a PIN re-save.
# Generate with:  openssl rand -hex 32
PAYLOAD_PIN_PEPPER=

# ── Public URLs / trusted origins ─────────────────────────────────────────────
# The dashboard's OWN public origin — REQUIRED for the admin auth cookie to be
# trusted (CSRF/CORS). Prod: https://admin.metnmat.com
CMS_URL=http://localhost:3001
NEXT_PUBLIC_SERVER_URL=http://localhost:3001
# Public website origin (allowed to read the CMS API cross-origin). Prod: https://www.metnmat.com
WEBSITE_URL=http://localhost:3000

# ── Server ↔ server trust ─────────────────────────────────────────────────────
# Shared secret the website server presents as `x-internal-key` to write orders /
# read private enquiry files / trigger revalidation. MUST match the website's
# INTERNAL_API_KEY. (Recommended: split into per-purpose keys — see audit.)
INTERNAL_API_KEY=
# OPTIONAL per-purpose keys (SEC-06) — set the SAME value on BOTH apps, or leave
# blank to use INTERNAL_API_KEY. Limits blast radius if one key leaks.
CMS_ORDER_WRITE_KEY=
CMS_TICKET_WRITE_KEY=
CMS_REVALIDATE_KEY=

# ── Chatbot product sync ──────────────────────────────────────────────────────
# Mongo DB name the chatbot reads published products from (sync-chatbot hook).
CHATBOT_DB_NAME=metnmat

# ── Object storage (Google Cloud Storage) ─────────────────────────────────────
# Enabled when GCS_BUCKET + GCS_PROJECT_ID are set. On Cloud Run the attached
# service account supplies credentials (leave GCS_KEY_FILENAME unset → ADC).
# The bucket MUST be private (uniform bucket-level access, no allUsers).
GCS_BUCKET=
GCS_PROJECT_ID=
GCS_KEY_FILENAME=

# ── Currency ──────────────────────────────────────────────────────────────────
# Open Exchange Rates app id for the ₹/$ rate shown to staff.
OPEN_EXCHANGE_RATES_APP_ID=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=
