# ── Dashboard (Payload CMS) environment ───────────────────────────────────────
# Copy to `.env` (gitignored) and fill in. NEVER commit real secrets.

# Payload
# Generate locally: openssl rand -base64 32
PAYLOAD_SECRET=
# Public URL this dashboard is served from
NEXT_PUBLIC_SERVER_URL=http://localhost:3001

# ── Database: MongoDB Atlas (single source of truth) ──────────────────────────
# Atlas → create cluster → DB user → allow IP → copy connection string.
MONGODB_URI=
MONGODB_DB=metnmat

# ── Object storage: Google Cloud Storage ─────────────────────────────────────
# GCP → create a bucket → service account with "Storage Object Admin" → JSON key.
# When these are empty, the dashboard falls back to LOCAL DISK storage for dev.
GCS_PROJECT_ID=
GCS_BUCKET=
# Absolute path to the service-account JSON key file (keep it OUT of git):
GCS_KEY_FILENAME=
# Public base URL for served assets (bucket public URL or CDN domain):
GCS_PUBLIC_URL=

# CORS / CSRF: the public website origin that may read the API
WEBSITE_URL=http://localhost:3000
