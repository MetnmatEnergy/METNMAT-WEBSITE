# ── Website environment ───────────────────────────────────────────────────────
# Copy to `.env.local` (gitignored) and fill in. Never commit real secrets.

# Public site URL (used for canonical URLs, sitemap, OG tags).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Database (MongoDB Atlas — single source of truth) ──────────────────────────
# TODO(backend): set when wiring the DB. See src/backend/db/mongo.ts
MONGODB_URI=
MONGODB_DB=metnmat

