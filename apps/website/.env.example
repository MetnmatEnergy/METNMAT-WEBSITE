# ── Website environment ───────────────────────────────────────────────────────
# Copy to `.env.local` (gitignored) and fill in. NEVER commit real secrets.
# This file lists exactly the variables the website code reads (grep process.env).

# ── Core URLs ─────────────────────────────────────────────────────────────────
# Public site URL — canonical URLs, sitemap, OG tags, email links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Payload CMS (dashboard) base URL — the website reads ALL catalog + content from
# here via its REST API. Prod: https://admin.metnmat.com
NEXT_PUBLIC_CMS_URL=http://localhost:3001
# Customer chatbot base URL (chat widget). Optional.
NEXT_PUBLIC_CHATBOT_URL=

# ── Server ↔ CMS trust ────────────────────────────────────────────────────────
# Shared secret sent as `x-internal-key` so ONLY the website server can create
# orders / read order+enquiry history / trigger revalidation. MUST match the
# dashboard's INTERNAL_API_KEY. Required in production.
INTERNAL_API_KEY=

# ── Payments (Razorpay) ───────────────────────────────────────────────────────
# Test: rzp_test_xxx / Live: rzp_live_xxx. Online checkout is disabled if unset.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook secret from the Razorpay dashboard — authoritative payment confirmation
# (reconciles payments even if the buyer's browser dies after paying).
RAZORPAY_WEBHOOK_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Order/quote/support confirmations. Emails are skipped (no-op) if unset.
RESEND_API_KEY=
# Must be on a Resend-verified domain (e.g. noreply@metnmat.com). Falls back to
# the Resend sandbox sender when unset (dev only).
QUOTE_FROM_EMAIL=
# Internal inbox that receives order/quote/support notifications.
QUOTE_NOTIFY_EMAIL=

# ── Currency (optional) ───────────────────────────────────────────────────────
# Open Exchange Rates app id for the live ₹/$ display rate. Falls back to a
# keyless rate API, then the CMS commerce rate, then 84. USD is display-only;
# every charge is always in INR.
OPEN_EXCHANGE_RATES_APP_ID=

# ── Hardening (recommended before public launch) ──────────────────────────────
# Shared rate-limit store across Cloud Run instances (in-memory limiter is
# per-instance only). Optional today.
# REDIS_URL=
# Cloudflare Turnstile for bot protection on auth/contact forms. Optional today.
# TURNSTILE_SECRET_KEY=
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
